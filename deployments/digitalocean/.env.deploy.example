# DigitalOcean Deployment Configuration
# Copy this file to .env.deploy and fill in your actual values
# This file is gitignored and will not be committed to your repository

# Required: Your DigitalOcean Personal Access Token
# Get it from: https://cloud.digitalocean.com/account/api/tokens
# Make sure it has "Write" scope
DO_ACCESS_TOKEN=pat_XXXXXXXXXXXXXXXXXXXXXXXX

# Required: Your AfterShip API Key
# Get it from: https://accounts.aftership.com/register
VITE_AFTERSHIP_API_KEY=your-aftership-key

# Required: Supabase (used by PO Info + scanner)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Required: Your GitHub repository (username/repo-name)
DO_GITHUB_REPO=Paeddle/CursorTestProjectApp

# Optional: GitHub branch to deploy (default: main)
DO_GITHUB_BRANCH=main

# Optional: App name on DigitalOcean
DO_APP_NAME=cursor-test-project-app

# Optional: DigitalOcean region (default: nyc)
# Other options: sfo, nyc, ams, sgp, lon, fra, tor, blr, sfo3, nyc3, ams3, sgp1, lon1, fra1, tor1, blr1
DO_REGION=nyc

# Optional: Barcode Lookup – ADI web search (get key from https://serper.dev)
# VITE_SERPER_API_KEY=
